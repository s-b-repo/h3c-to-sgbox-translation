[server]
syslog_tls_port = 6514
syslog_tcp_port = 5140
syslog_udp_port = 5140
api_port = 8443
bind_address = 127.0.0.1
max_connections = 100
daemonize = false

[tls]
cert_file = /tmp/h3c-test-certs/server.crt
key_file = /tmp/h3c-test-certs/server.key
ca_file = /tmp/h3c-test-certs/server.crt
require_client_cert = false
min_tls_version = TLSv1.2

[security]
allowed_ips = 0.0.0.0
api_key =
allow_plaintext = true

[sgbox]
mode = push
output_port = 1514
host = 127.0.0.1
port = 5141
protocol = tls
facility = local0
severity = info

[output]
format = extended
include_hostname = true
include_timestamp = true

[encryption]
enabled = false

[logging]
level = DEBUG
file =
