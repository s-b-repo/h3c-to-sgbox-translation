[server]
# Syslog listener ports
syslog_tls_port = 6514
syslog_tcp_port = 514
syslog_udp_port = 514
# HTTPS API port
api_port = 8443
# Bind address — use 0.0.0.0 to accept connections from H3C firewalls/SGBox
bind_address = 0.0.0.0
# Maximum concurrent connections
max_connections = 100
# Run as background daemon (true/false)
daemonize = false
# PID file for daemon mode
pid_file = /var/run/h3c-translator.pid

[tls]
# Path to server certificate (PEM format)
cert_file = /etc/h3c-translator/certs/server.crt
# Path to server private key (PEM format)
key_file = /etc/h3c-translator/certs/server.key
# Path to CA bundle for verifying SGBox's TLS certificate (auto-fetched by install.sh)
ca_file = /etc/h3c-translator/certs/ca-bundle.pem
# Require client certificate authentication (true/false)
require_client_cert = false
# Minimum TLS version: TLSv1.2 or TLSv1.3
min_tls_version = TLSv1.2

[security]
# Comma-separated list of allowed source IPs (CIDR supported)
# Only connections from these IPs will be accepted
# ⚠ CHANGE THIS — 0.0.0.0 allows ALL IPs (insecure)
# Example: allowed_ips = 10.16.18.1,10.13.0.1,10.17.0.1,192.168.1.0/24
allowed_ips = 0.0.0.0
# API key for authenticating REST API requests (CRIT-01)
# Generate with: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
api_key = CHANGE_ME_GENERATE_A_SECURE_KEY
# Allow plain HTTP when TLS certs are not configured (NOT recommended for production)
allow_plaintext = false
# (Informational) Ports this service is expected to bind to — not enforced in code
allowed_ports = 6514,514,8443

[sgbox]
# Mode: pull or push
# pull = SGBox Collector connects to this translator to pull logs
# push = Translator pushes logs to SGBox over TCP/TLS (recommended with TLS)
mode = push
# Port that SGBox Collector connects to (pull mode)
output_port = 1514
# SGBox SIEM server address (push mode) — use external/routable IP
# Supports multiple destinations: comma-separated hosts for parallel fan-out
# Example: host = 10.10.0.52,10.10.0.53,10.10.0.54
host = 10.10.0.52
# SGBox syslog TLS receiving port (push mode)
port = 6154
# Protocol to use: udp, tcp, or tls
protocol = tls
# SGBox API key — required by SGBox for log ingestion on port 6154
# Get this from SGBox console: SCM → Configuration → API Keys
sgbox_api_key = CHANGE_ME_SET_YOUR_SGBOX_API_KEY
# Syslog facility (local0-local7, user, daemon, etc.)
facility = local0
# Syslog severity (emerg, alert, crit, err, warning, notice, info, debug)
severity = info

[output]
# Output format: core (minimal fields) or extended (all fields)
# core:     proto src dst sport dport action
# extended: core + app nat_src nat_dst nat_sport nat_dport hostname category
format = extended
# Include firewall hostname in output (true/false)
include_hostname = true
# Include original timestamp in output (true/false)
include_timestamp = true

[encryption]
# SGBox-compatible GPG encryption at rest
# NOTE: SGBox does not allow configuring the GPG passphrase,
# so TLS transport (protocol = tls in [sgbox]) is the recommended
# security mechanism. GPG encryption is disabled by default.
# Enable/disable encryption (true/false)
enabled = false
# GPG keyring directory
gpg_home = /var/lib/h3c-translator/.gnupg
# Path to gpg binary
gpg_binary = gpg
# Encryption mode: symmetric (passphrase) or asymmetric (key)
mode = symmetric
# Passphrase for symmetric encryption (CHANGE THIS!)
passphrase = CHANGE_ME_USE_A_STRONG_PASSPHRASE
# Recipient key ID or email for asymmetric mode
recipient =
# Cipher algorithm (AES256, AES192, AES128, CAST5, 3DES)
cipher_algo = AES256
# ASCII-armored output (true/false) — false = binary (more compact)
armor = false
# Encrypt messages before forwarding to SGBox (true/false)
encrypt_output = true
# Directory for encrypted log files
encrypted_log_dir = /var/log/h3c-translator/encrypted

[logging]
# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
level = INFO
# Log file path
file = /var/log/h3c-translator/translator.log
# Maximum log file size in MB before rotation
max_size_mb = 100
# Number of rotated log files to keep
backup_count = 5
